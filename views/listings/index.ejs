<% layout("/layouts/boilerplate") %>
<body>
    <h3>All Listings</h3>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 justify-content-center">
        <% for(let listing of allListings) { %>
            <!-- <div class="card cols" style="width: 17.8rem;"> -->
            <a href="/listing/<%= listing._id %>" class="listing-link">
                <div class="card cols listing-card">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 17.8rem;">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listing.title %></b><br>
                            &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                        </p>
                    </div>
                </div>
            </a>
        <% } %>
    </div>




    <!-- <ul>
        <% for(let listing of allListings) { %>
            <li><a href="/listing/<%= listing._id %>"><%= listing.title %></a></li>
        <% } %>
    </ul> -->

</body>
